# ground-reporter 环境变量示例
# 复制本文件为 .env 并填入真实值

# ── 6.1 预警/报警写入接口（按协议章节 6.1 独立配置）
FAULT_RECORD_URL=https://clznyw7.nbmetro.com/gate/METRO-PHM/api/faultRecordsSubsystem/saveRecord

# ── 6.6 运行状态心跳接口（按协议章节 6.6 独立配置）
SYS_STATUS_URL=https://clznyw7.nbmetro.com/gate/METRO-SELFCHECK-SUBSYSTEM/api/faultRecordsSubsystem/saveStatus

# ── 6.7 寿命状态数据接口（按协议章节 6.7 独立配置）
LIFE_RECORD_URL=https://clznyw7.nbmetro.com/gate/METRO-PHM/api/devices/status/train/saveOrUpdate

# ── 平台认证与 HTTP 参数（三个接口共享）
PLATFORM_API_KEY=
PLATFORM_TIMEOUT_SEC=10
PLATFORM_RETRY_MAX=3
PLATFORM_RETRY_BACKOFF_MS=1000

# ── 空调子系统标识（固定）
SUBSYSTEM_CODE=5
TRAIN_TYPE=B

# ── 心跳周期（分钟）与每日批量报送时刻（小时，0=凌晨）
HEARTBEAT_INTERVAL_MIN=10
DAILY_BATCH_HOUR=0

# ── Kafka
KAFKA_BROKERS=redpanda-1:9092,redpanda-2:9092,redpanda-3:9092

# ── 日志级别（INFO | DEBUG）
LOG_LEVEL=INFO
